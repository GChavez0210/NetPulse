{
  "name": "netpulse",
  "version": "0.1.1",
  "description": "Desktop app for basic network troubleshooting with Electron + React + Vite",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "clean:install": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path node_modules) { Remove-Item -Recurse -Force node_modules }; if (Test-Path package-lock.json) { Remove-Item -Force package-lock.json }; npm install\"",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build:web": "vite build",
    "build": "npm run build:web && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "vite": "^7.3.1",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.netpulse.app",
    "productName": "NetPulse",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "netpulse_icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "netpulse_icon.ico",
      "uninstallerIcon": "netpulse_icon.ico",
      "installerHeaderIcon": "netpulse_icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
