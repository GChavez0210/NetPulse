{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetPulse",
  "version": "0.1.2",
  "identifier": "com.netpulse.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NetPulse",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 560,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../assets/oui-database.sqlite"]
  }
}
